{% extends 'base.html.twig' %}

{% block title %}Commande{% endblock %}

{% block body %}
    <h1>Commande</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ commande.id }}</td>
            </tr>
            <tr>
                <th>Numero</th>
                <td>{{ commande.numero }}</td>
            </tr>
            <tr>
                <th>Statut</th>
                <td>{{ commande.statut }}</td>
            </tr>
            <tr>
                <th>Total</th>
                <td>{{ commande.total }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ commande.createdAt ? commande.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>ValidatedAt</th>
                <td>{{ commande.validatedAt ? commande.validatedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_commande_index') }}">back to list</a>

    <a href="{{ path('app_commande_edit', {'id': commande.id}) }}">edit</a>

    {% if commande.statut == 'panier' or commande.statut == 'en_attente' %}
        <form method="post" action="{{ path('app_commande_valider', {'id': commande.id}) }}" style="display:inline">
            <input type="hidden" name="_token" value="{{ csrf_token('valider' ~ commande.id) }}">
            <button type="submit" onclick="return confirm('Confirmer la validation de cette commande ?')">
                Valider la commande
            </button>
        </form>
    {% endif %}

    {{ include('commande/_delete_form.html.twig') }}
{% endblock %}
